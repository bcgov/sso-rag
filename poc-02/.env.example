# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# The ID of your AWS Bedrock Knowledge Base
KNOWLEDGE_BASE_ID=

# ---------------------------------------------------------------------------
# Optional – override defaults
# ---------------------------------------------------------------------------

# AWS region where the Knowledge Base and models are deployed
AWS_REGION=ca-central-1

# Mistral AI 7B Instruct foundation model ARN
MODEL_ARN=

# Amazon Rerank foundation model ARN (used for reranking retrieved results)
RERANKER_MODEL_ARN=

# How many documents to retrieve from the knowledge base before reranking
NUMBER_OF_RESULTS=5

# How many documents to keep after reranking
NUMBER_OF_RERANKED_RESULTS=3

# Comma-separated list of allowed CORS origins (default: all)
# CORS_ORIGINS=["https://your-frontend.example.com"]

# ---------------------------------------------------------------------------
# AWS credentials – ONLY for local development without an IAM role.
# In production use an IAM role (EC2/ECS/EKS) – never commit credentials.
# ---------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
